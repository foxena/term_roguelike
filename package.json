{
  "name": "term_roguelike",
  "version": "0.1.0",
  "description": "A fast-paced terminal roguelike with hordes of enemies, built on OpenTUI",
  "type": "module",
  "module": "src/main.ts",
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch run src/main.ts",
    "proto": "bun run scripts/render-proto.ts",
    "legacy": "bun run legacy/terminal/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
